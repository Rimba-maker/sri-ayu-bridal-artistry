---
import { timKami } from "../data/content";
---

<section class="bg-canvas-ceramic px-6 py-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h2 class="font-serif text-3xl md:text-4xl text-ink mb-4">{timKami.heading}</h2>
      <p class="font-sans text-body">{timKami.body}</p>
    </div>

    <div class="grid grid-cols-3 gap-4">
      {timKami.roles.map((role) => (
        <div class="bg-surface rounded-card p-6 text-center shadow-[0_0_0.5px_rgba(0,0,0,0.14),0_1px_1px_rgba(0,0,0,0.24)]">
          <div class="w-16 h-16 mx-auto rounded-full bg-maroon-uplift/20 flex items-center justify-center font-serif text-xl text-maroon">
            {role.split(" ").map((w) => w[0]).join("")}
          </div>
          <p class="font-sans text-sm font-semibold text-ink mt-3">{role}</p>
          <p class="font-sans text-xs text-body-soft mt-1">Nama & foto menyusul</p>
        </div>
      ))}
    </div>
  </div>
</section>
