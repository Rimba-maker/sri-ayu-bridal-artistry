---
import { nav } from "../data/content";
---

<header class="sticky top-0 z-50 bg-canvas/90 backdrop-blur-sm border-b border-maroon/10">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    <a href="#" class="font-serif text-2xl text-maroon">Sri Ayu</a>

    <nav class="hidden md:flex items-center gap-8">
      {nav.links.map((link) => (
        <a href={link.href} class="font-sans text-sm text-body hover:text-maroon-accent transition-colors">
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="#cta-booking"
      class="rounded-pill bg-maroon-accent text-on-dark font-sans text-sm font-semibold px-6 py-2.5 active:scale-95 transition-transform"
    >
      {nav.cta}
    </a>
  </div>
</header>
