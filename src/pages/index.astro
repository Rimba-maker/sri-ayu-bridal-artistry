---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import TimKami from "../components/TimKami.astro";
import Hero from "../components/Hero";
import PainPoints from "../components/PainPoints";
import RiasanAdat from "../components/RiasanAdat";
import Teknik from "../components/Teknik";
import Paket from "../components/Paket";
import TrialSession from "../components/TrialSession";
import Portfolio from "../components/Portfolio";
import Testimonial from "../components/Testimonial";
import FAQ from "../components/FAQ";
import BookingForm from "../components/BookingForm";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      name: "Sri Ayu Bridal Artistry",
      description:
        "MUA pengantin spesialis riasan adat tradisional (paes, sunting, siger) dan teknik modern tahan lama.",
      priceRange: "Rp 500.000 - Rp 12.000.000",
      areaServed: "ID",
    },
    {
      "@type": "Service",
      serviceType: "Riasan Pengantin",
      provider: { "@type": "LocalBusiness", name: "Sri Ayu Bridal Artistry" },
      areaServed: "ID",
    },
  ],
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Navbar />
  <Hero client:load />
  <PainPoints client:visible />
  <RiasanAdat client:visible />
  <Teknik client:visible />
  <Paket client:visible />
  <TrialSession client:visible />
  <TimKami />
  <Portfolio client:visible />
  <Testimonial client:visible />
  <FAQ client:visible />
  <BookingForm client:idle />
  <Footer />
</Layout>
