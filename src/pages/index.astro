---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="min-h-screen bg-canvas flex items-center justify-center px-6">
    <div class="max-w-2xl text-center">
      <p class="font-sans text-sm tracking-widest uppercase text-maroon-accent mb-4">
        Sri Ayu Bridal Artistry
      </p>
      <h1 class="font-serif text-5xl text-ink mb-6">
        Riasan Yang Bertahan Sepanjang Hari Bahagiamu.
      </h1>
      <p class="font-sans text-body mb-8">
        MUA pengantin yang menguasai riasan adat tradisional sekaligus teknik modern tahan lama.
      </p>
      <button class="rounded-pill bg-maroon-accent text-on-dark font-sans font-semibold px-8 py-3.5 active:scale-95 transition-transform">
        Booking Trial Makeup
      </button>
      <span class="ml-3 inline-block rounded-pill border border-gold text-gold font-sans text-sm px-4 py-2">
        ⭐ Terpopuler
      </span>
    </div>
  </main>
</Layout>
